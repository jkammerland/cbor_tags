{
  "name": "cbor-tags",
  "version": "0.15.0",
  "description": "RFC 8949 implementation with automatic reflection",
  "homepage": "https://github.com/jkammerland/cbor_tags",
  "license": "MIT",
  "builtin-baseline": "8f7641a3f5bb68d1d1b9f367039dcb08ac77671d",
  "dependencies": [
    {
      "name": "tl-expected",
      "version>=": "1.1.0"
    }
  ],
  "features": {
    "boost-pfr-names": {
      "description": "Install Boost.PFR dependencies for the optional C++20 named-map reflection backend.",
      "dependencies": [
        {
          "name": "boost-cmake",
          "version>=": "1.84.0"
        },
        {
          "name": "boost-config",
          "version>=": "1.84.0"
        },
        {
          "name": "boost-headers",
          "version>=": "1.84.0"
        },
        {
          "name": "boost-pfr",
          "version>=": "1.84.0"
        }
      ]
    },
    "magic-enum-names": {
      "description": "Install magic_enum dependencies for optional CDDL enum-name definitions.",
      "dependencies": [
        {
          "name": "magic-enum",
          "version>=": "0.9.7"
        }
      ]
    }
  }
}
