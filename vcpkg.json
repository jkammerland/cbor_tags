{
  "name": "cbor-tags",
  "version": "0.17.0",
  "description": "RFC 8949 implementation with automatic reflection",
  "homepage": "https://github.com/jkammerland/cbor_tags",
  "license": "MIT",
  "builtin-baseline": "a7f2963aed6b381ce54c0803330bb4de36cd3241",
  "dependencies": [
    {
      "name": "nameof",
      "version>=": "0.10.4"
    },
    {
      "name": "fmt",
      "version>=": "11.0.2"
    }
  ],
  "default-features": [
    "tl-expected"
  ],
  "features": {
    "tl-expected": {
      "description": "Install tl::expected dependencies for the default C++20 expected backend.",
      "dependencies": [
        {
          "name": "tl-expected",
          "version>=": "1.1.0"
        }
      ]
    },
    "std-expected": {
      "description": "Use the C++23 std::expected backend without installing tl::expected."
    },
    "boost-pfr-names": {
      "description": "Install Boost.PFR dependencies for the optional C++20 named-map reflection backend.",
      "dependencies": [
        {
          "name": "boost-cmake",
          "version>=": "1.84.0"
        },
        {
          "name": "boost-config",
          "version>=": "1.84.0"
        },
        {
          "name": "boost-headers",
          "version>=": "1.84.0"
        },
        {
          "name": "boost-pfr",
          "version>=": "1.84.0"
        }
      ]
    },
    "magic-enum-names": {
      "description": "Install magic_enum dependencies for optional CDDL enum-name definitions.",
      "dependencies": [
        {
          "name": "magic-enum",
          "version>=": "0.9.8"
        }
      ]
    }
  }
}
