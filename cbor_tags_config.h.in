#pragma once

#ifndef CBOR_TAGS_DEBUG
#cmakedefine01 CBOR_TAGS_DEBUG
#endif

#ifndef CBOR_TAGS_STL_ONLY
#cmakedefine01 CBOR_TAGS_STL_ONLY
#endif

#ifndef CBOR_TAGS_USE_STD_REFLECTION
#cmakedefine01 CBOR_TAGS_USE_STD_REFLECTION
#endif

#ifndef CBOR_TAGS_USE_BOOST_PFR_NAMES
#cmakedefine01 CBOR_TAGS_USE_BOOST_PFR_NAMES
#endif

#ifndef CBOR_TAGS_USE_MAGIC_ENUM_NAMES
#cmakedefine01 CBOR_TAGS_USE_MAGIC_ENUM_NAMES
#endif

#ifndef CBOR_TAGS_USE_STD_EXPECTED
#cmakedefine01 CBOR_TAGS_USE_STD_EXPECTED
#endif

#include <string_view>

#if CBOR_TAGS_DEBUG == 1
#if CBOR_TAGS_STL_ONLY == 1
#include <format>
#include <print>
#include <string>
#else
#include <fmt/format.h>
#endif
#endif

namespace cbor::tags::debug {
struct ConfigConstants {
    static constexpr bool debug_enabled{CBOR_TAGS_DEBUG == 1};
};

template <typename... Args> inline constexpr void print([[maybe_unused]] std::string_view fmt, [[maybe_unused]] const Args &...args) {
#if CBOR_TAGS_DEBUG == 1
    if constexpr (ConfigConstants::debug_enabled) {
    #if CBOR_TAGS_STL_ONLY == 1
        std::print("{}", std::vformat(std::string(fmt), std::make_format_args(args...)));
    #else
        fmt::print(fmt::runtime(fmt), args...);
    #endif
    }
#endif
}

template <typename... Args> inline constexpr void println([[maybe_unused]] std::string_view fmt, [[maybe_unused]] const Args &...args) {
#if CBOR_TAGS_DEBUG == 1
    if constexpr (ConfigConstants::debug_enabled) {
        print(fmt, args...);
    #if CBOR_TAGS_STL_ONLY == 1
        std::print("\n");
    #else
        fmt::print("\n");
    #endif
    }
#endif
}

} // namespace cbor::tags::debug
